{
  "manifest_version": 3,
  "name": "hetu - Hide SSN on Finnish authentication sites",
  "version": "1.0.2",
  "description": "Hides visible Social security numbers (henkilötunnus aka hetu) values on selected Finnish authentication pages using pure CSS.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://userapi2.danskebank.com/prod/external*",
        "https://tunnistautuminen.suomi.fi/idp/profile*",
        "https://online.s-pankki.fi/ftn/initSession*"
      ],
      "css": ["hide.css"],
      "run_at": "document_idle"
    }
  ]
}
